# global options
{
	admin off
	persist_config off
	auto_https off

	log {
		format json
	}

	servers {
		trusted_proxies static private_ranges 100.0.0.0/8 # trust railway's proxy
	}
}

# site block, listens on the $PORT environment variable, automatically assigned by railway
:{$PORT:80} {
	log {
		format json
	}

	respond /health 200

	# Security headers + default cache (short-lived for HTML, txt, etc.)
	header {
		X-Content-Type-Options "nosniff"
		-Server
		Cache-Control "public, max-age=0, must-revalidate"
	}

	# Override: immutable SvelteKit assets — content-hashed filenames, safe to cache forever
	header /_app/immutable/* {
		Cache-Control "public, max-age=31536000, immutable"
	}

	# serve from the root directory
	root * {{.DIST_DIR}}

	# Handle static files
	file_server {
		hide .git
		hide .env*
	}

	# Compression — zstd first, gzip fallback (brotli not included in stock Caddy build)
	encode {
		zstd
		gzip
	}

	# match against direct file matches, folder-level index.html, and optionally fallback to root index.html
	try_files {path} {path}.html {path}/index.html{{if .IndexFallback}} /index.html{{end}}
}
